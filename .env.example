# pocket-tts-lab is zero-config by default — no keys needed.
# These are ONLY for the optional "cloud race" panel in the "Why care" tab.
# Leave them unset and the app runs 100% locally.

# OpenAI — used for the optional "cloud race" (tts-1) AND as a fallback brain
# for the Converse demo's replies. Optional.
# OPENAI_API_KEY=

# xAI (Grok) — preferred brain for the Converse demo when set (xAI is OpenAI-
# compatible). Optional; falls back to OpenAI, then a local demo brain.
# XAI_API_KEY=
# XAI_MODEL=grok-3-mini

# ElevenLabs — optional comparison lane.
# ELEVENLABS_API_KEY=

# Where the Python TTS sidecar listens (defaults shown). The Next dev runner
# (scripts/dev.ts) reads TTS_PORT to spawn + proxy the backend.
# TTS_PORT=4706
